{
  // ============================================================================
  // CRITICAL: Database configuration - DO NOT modify without team discussion
  // Contains: Database connection string and logging settings
  // ============================================================================
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=./database.db"
  },
  "ApiSettings": {
    "BaseUrl": "https://localhost:7000",
    "CorsOrigins": ["http://localhost:3000", "http://127.0.0.1:3000", "file://"]
  }
}
